---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Kerman', href: '/locations/kerman' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Kerman',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/kerman',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.7236,
    longitude: -120.0598,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Kerman' },
    { '@type': 'City', name: 'Fresno' },
    { '@type': 'City', name: 'San Joaquin' },
    { '@type': 'City', name: 'Firebaugh' },
    { '@type': 'City', name: 'Mendota' },
    { '@type': 'City', name: 'Biola' },
    { '@type': 'City', name: 'Tranquillity' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Kerman, CA?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The average residential solar installation in Kerman costs between $14,000-$28,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$19,600. System size depends on your energy usage — most Kerman homes need 5-10 kW systems. Solar Center offers $0-down financing options to make solar affordable for every household.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why is Kerman a good place for solar panels?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Kerman enjoys approximately 275 sunny days per year, making it one of the best locations in California for solar energy production. The hot Central Valley summers drive high air conditioning costs on PG&E bills, and solar panels dramatically reduce those expenses. Kerman homeowners typically see a full return on their solar investment within 6-8 years.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Solar Center install solar panels in Kerman?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, Solar Center by Dura-Foam serves Kerman and the surrounding west Fresno County area including Fresno, San Joaquin, Firebaugh, Mendota, Biola, and Tranquillity. We handle everything from system design and Fresno County permitting to PG&E interconnection and ongoing support.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Kerman CA | Local Solar Company | Solar Center"
  description="Kerman's trusted solar installer. 275+ sunny days, big savings on PG&E bills. Free consultation, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Kerman, CA"
    subtitle="Affordable solar energy for Kerman's growing community. 275+ sunny days. Cut your PG&E bills dramatically."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Kerman's Trusted Solar Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Kerman is a small but fast-growing agricultural community just west of Fresno, and Solar Center by Dura-Foam is proud to help its residents make the switch to solar energy. With new homes going up and families putting down roots, solar is one of the smartest investments Kerman homeowners can make — reducing energy costs from day one while adding lasting value to your property.</p>
              <p>With approximately 275 sunny days per year and scorching Central Valley summers, Kerman residents face some of the highest PG&E bills in the state. A properly sized solar system can eliminate 75-85% of your electricity costs, turning that relentless sunshine into real monthly savings instead of sweltering utility bills.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Kerman Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">275+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$170+</p>
                <p class="text-sm text-slate">Average monthly summer bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Kerman Neighborhoods & Areas We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Downtown Kerman', 'North Kerman', 'South Kerman', 'West Kerman', 'Whitesbridge Area', 'Shields Avenue Corridor', 'Fresno', 'San Joaquin', 'Firebaugh', 'Mendota', 'Biola', 'Tranquillity'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Kerman Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Kerman, CA?', a: 'The average residential solar installation in Kerman costs between $14,000-$28,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$19,600. We offer $0-down financing options to make solar affordable.' },
                { q: 'Why is Kerman a good place for solar panels?', a: 'Kerman enjoys approximately 275 sunny days per year, making it one of the best locations in California for solar. The hot Central Valley summers drive high AC costs on PG&E bills, and solar panels dramatically reduce those expenses.' },
                { q: 'Does Solar Center install solar panels in Kerman?', a: 'Yes, Solar Center by Dura-Foam serves Kerman and the surrounding west Fresno County area including Fresno, San Joaquin, Firebaugh, Mendota, Biola, and Tranquillity. We handle everything from design to PG&E interconnection.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Kerman Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners throughout the Central Valley." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Reedley', cities: 'Reedley, Sanger, Dinuba, Orange Cove', href: '/locations/reedley' },
          { name: 'Stockton', cities: 'Stockton, Modesto, Merced', href: '/locations/stockton' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
