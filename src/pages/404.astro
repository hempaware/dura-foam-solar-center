---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Solar Center by Dura-Foam" noindex={true}>
  <section class="py-32 text-center">
    <div class="mx-auto max-w-2xl px-4">
      <h1 class="text-6xl font-extrabold text-solar-navy font-headline mb-4">404</h1>
      <p class="text-xl text-slate mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center rounded-lg bg-solar-amber px-8 py-4 text-base font-bold text-midnight no-underline transition hover:bg-[#e6951a] font-label">
          Back to Home
        </a>
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg border-2 border-solar-navy px-8 py-4 text-base font-bold text-solar-navy no-underline transition hover:bg-solar-navy hover:text-white font-label">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
