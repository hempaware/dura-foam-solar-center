---
interface Props {
  title: string;
  subtitle?: string;
  badge?: string;
  align?: 'center' | 'left';
}

const { title, subtitle, badge, align = 'center' } = Astro.props;
---

<div class:list={['mb-12', align === 'center' ? 'text-center' : 'text-left']}>
  {badge && (
    <span class="inline-block rounded-full border border-slate/30 px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-slate mb-4 font-label">
      {badge}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl font-bold text-solar-navy font-headline leading-tight max-w-3xl mx-auto">{title}</h2>
  {subtitle && <p class="mt-4 text-lg text-slate max-w-2xl mx-auto">{subtitle}</p>}
</div>
