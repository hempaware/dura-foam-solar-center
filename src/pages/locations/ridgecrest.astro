---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Ridgecrest', href: '/locations/ridgecrest' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Ridgecrest',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/ridgecrest',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 35.6225,
    longitude: -117.6709,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Ridgecrest' },
    { '@type': 'City', name: 'Inyokern' },
    { '@type': 'City', name: 'China Lake' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Ridgecrest?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Solar installations in Ridgecrest typically cost between $14,000-$29,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$20,300. Ridgecrest homes generally need 6-12 kW systems to offset high desert cooling costs. Military families may qualify for additional incentives. We offer $0-down financing.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Ridgecrest good for solar panels?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ridgecrest is one of the best locations for solar in all of California. With 300+ sunny days per year in the Indian Wells Valley, the area receives some of the highest solar irradiance in the nation. SCE serves Ridgecrest, and the extreme desert heat drives high electricity costs that solar can reduce by 85% or more.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long do solar panels last in Ridgecrest?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Solar panels installed in Ridgecrest are built to last 25-30+ years. We select panels specifically rated for desert environments — engineered to handle extreme heat, intense UV radiation, and dust. Manufacturers warranty panels for 25 years, and they typically maintain 85-90% output over that period.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Ridgecrest CA | Local Solar Company | Solar Center"
  description="Ridgecrest's trusted solar installer. 300+ sunny days in the Indian Wells Valley. Desert-rated panels, military-friendly service. Free consultation. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Ridgecrest, CA"
    subtitle="300+ sunny days in the Indian Wells Valley. One of California's best locations for solar energy."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Ridgecrest's Trusted Solar Partner</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Ridgecrest sits at the gateway to the Indian Wells Valley, adjacent to Naval Air Weapons Station China Lake — one of the largest military installations in the world. This unique desert community combines a strong defense and aerospace workforce with small-town values and some of the most intense sunshine in all of California. Solar Center by Dura-Foam helps Ridgecrest homeowners turn that sunshine into lasting savings.</p>
              <p>With over 300 sunny days per year, Ridgecrest receives some of the highest solar irradiance in the nation. That's a powerful asset when SCE electricity bills soar during the desert summer months, with temperatures regularly exceeding 110 degrees. Air conditioning runs nearly nonstop, driving monthly bills past $220 for many homes. Solar panels put you back in control — typically reducing those bills by 85% or more.</p>
              <p>Many Ridgecrest residents are military families or defense industry professionals who value energy independence and long-term planning. Solar is both: a smart financial investment that pays for itself within 5-7 years and a step toward energy self-sufficiency. Our team handles everything from SCE interconnection to city permitting, delivering the reliable, professional service this community expects.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Ridgecrest Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">300+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$220+</p>
                <p class="text-sm text-slate">Average monthly summer bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">85%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Ridgecrest Areas We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Ridgecrest', 'Inyokern', 'China Lake', 'Trona', 'Randsburg', 'Johannesburg', 'Red Mountain', 'Searles Valley'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Ridgecrest Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Ridgecrest?', a: 'Solar installations in Ridgecrest typically cost $14,000-$29,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$20,300. Military families may qualify for additional incentives. We offer $0-down financing.' },
                { q: 'Is Ridgecrest good for solar panels?', a: 'Ridgecrest is one of the best locations for solar in California. With 300+ sunny days per year, the Indian Wells Valley receives exceptional solar irradiance. Extreme desert heat drives high SCE bills that solar can slash by 85% or more.' },
                { q: 'How long do solar panels last in Ridgecrest?', a: 'Solar panels last 25-30+ years even in Ridgecrest\'s extreme desert climate. We select desert-rated panels engineered for intense heat, UV, and dust. 25-year manufacturer warranties cover performance, with panels maintaining 85-90% output over that period.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Ridgecrest Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners throughout the Central Valley." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Downtown, Stockdale', href: '/locations/bakersfield' },
          { name: 'California City', cities: 'California City, Mojave', href: '/locations/california-city' },
          { name: 'Tehachapi', cities: 'Tehachapi, Bear Valley Springs', href: '/locations/tehachapi' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
