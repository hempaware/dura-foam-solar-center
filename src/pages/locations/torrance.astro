---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Torrance', href: '/locations/torrance' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Torrance',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/torrance',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, #5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 33.8358,
    longitude: -118.3406,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Torrance' },
    { '@type': 'City', name: 'Gardena' },
    { '@type': 'City', name: 'Redondo Beach' },
    { '@type': 'City', name: 'Lomita' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Torrance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Torrance costs between $15,000-$30,000 before the 30% federal tax credit. Torrance\'s strong property values mean solar adds significant home equity while cutting energy costs. We offer $0-down financing options to make solar affordable for every homeowner.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does coastal fog affect solar panels in Torrance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Minimally. The South Bay marine layer typically burns off by mid-morning. Torrance still averages 285 sunny days per year, and modern panels produce energy even in diffused light. Your solar system will generate excellent production throughout the year.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is solar worth it in the South Bay?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. SCE rates continue to rise, and Torrance\'s mix of ranch-style homes with large south-facing roofs makes solar installation ideal. Most homeowners see 75% reduction in electricity bills. Combined with the 30% federal tax credit and SCE net metering, solar is one of the best investments South Bay homeowners can make.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Torrance CA | Expert Solar Installers | Solar Center"
  description="Torrance solar installation. South Bay solar experts, coastal-optimized systems. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Torrance, CA"
    subtitle="South Bay's trusted solar installer. Coastal-optimized systems. Maximum savings on SCE bills."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Torrance Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Torrance is one of the South Bay's premier communities for solar energy. Despite its coastal proximity, the marine layer typically burns off by mid-morning, leaving clear skies and 285 sunny days per year for excellent solar production. Solar Center by Dura-Foam brings decades of California solar expertise to Torrance and surrounding South Bay communities — from the charming streets of Old Torrance to the hillside homes of Hollywood Riviera.</p>
              <p>With SCE electricity rates continuing to rise, Torrance homeowners are making the smart move to solar. The city's mix of classic ranch-style homes and newer construction offers ideal rooftop conditions — large, south-facing roof planes that maximize solar panel placement. Strong property values in Torrance mean solar installations add significant home equity, making the investment even more attractive for homeowners planning to stay or sell.</p>
              <p>Torrance is home to major employers like Honda's North American headquarters and aerospace companies, creating a community of professionals who understand the value of smart investments. Our installation team designs coastal-optimized systems that account for the South Bay's unique microclimate, ensuring maximum energy generation year-round. Whether you're in Walteria, Seaside, or the Del Amo area, we'll create a solar solution that delivers real savings on your SCE bills.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Torrance Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">285</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$170+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Torrance Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Old Torrance', 'West Torrance', 'South Torrance', 'North Torrance', 'Walteria', 'Seaside', 'Hollywood Riviera', 'Gardena', 'Redondo Beach', 'Lomita', 'Harbor Gateway', 'Del Amo', 'Southwood', 'Meadow Park', 'El Nido'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Torrance Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Torrance?', a: 'A typical residential solar installation in Torrance costs between $15,000-$30,000 before the 30% federal tax credit. Torrance\'s strong property values mean solar adds significant home equity while cutting energy costs. We offer $0-down financing options for every budget.' },
                { q: 'Does coastal fog affect solar panels in Torrance?', a: 'Minimally. The South Bay marine layer typically burns off by mid-morning. Torrance still averages 285 sunny days per year, and modern panels produce energy even in diffused light.' },
                { q: 'Is solar worth it in the South Bay?', a: 'Absolutely. SCE rates continue to rise, and Torrance\'s mix of ranch-style homes with large south-facing roofs makes solar installation ideal. Most homeowners see 75% reduction in electricity bills.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Torrance Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, #5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 7:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Long Beach', cities: 'Long Beach, Signal Hill, Lakewood', href: '/locations/long-beach' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
