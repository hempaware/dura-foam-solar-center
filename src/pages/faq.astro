---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHero from '../components/PageHero.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'FAQ', href: '/faq' },
];

const faqs = [
  { category: 'Cost & Financing', items: [
    { q: 'How much does solar cost in Bakersfield?', a: 'The average residential solar installation costs between $15,000-$30,000 before the 30% federal tax credit. After the credit, most homeowners pay $10,500-$21,000. System size depends on your energy usage — most Central Valley homes need 6-12 kW systems.' },
    { q: 'What financing options are available?', a: 'We offer multiple financing options including $0-down solar loans with competitive interest rates, PACE financing through your property tax, and cash purchase for maximum ROI. All financing options let you own your system and keep the full tax credit.' },
    { q: 'What is the federal solar tax credit?', a: 'The Investment Tax Credit (ITC) allows you to deduct 30% of your total solar system cost from your federal taxes. For a $25,000 system, that\'s a $7,500 credit. The 30% rate is available through 2032, then drops to 26% in 2033 and 22% in 2034.' },
    { q: 'How much will I save on my electric bill?', a: 'Most homeowners see a 70-90% reduction in their electricity bills. In the Central Valley, where summer bills often exceed $300/month, that translates to $200-$270 in monthly savings. Over 25 years, total savings typically exceed $40,000.' },
  ]},
  { category: 'Installation & Equipment', items: [
    { q: 'How long does installation take?', a: 'The full process from consultation to activation typically takes 6-10 weeks. The actual roof installation takes just 1-3 days. Most of the timeline is for permitting and utility interconnection approvals.' },
    { q: 'What equipment do you use?', a: 'We use premium, high-efficiency solar panels and inverters from trusted manufacturers including Tier-1 panel brands. All equipment comes with manufacturer warranties of 25 years or more. We\'ll recommend the best equipment for your specific roof and energy needs during your consultation.' },
    { q: 'Will solar panels damage my roof?', a: 'No. Our installation methods are designed to protect your roof\'s integrity. As a division of Dura-Foam Roofing, we have deep expertise in roofing systems. All penetrations are properly sealed and flashed, and we warranty our workmanship.' },
    { q: 'Do I need a new roof before installing solar?', a: 'If your roof is more than 15 years old or shows signs of wear, we recommend evaluating it first. As a division of Dura-Foam Roofing, we can handle both roof replacement and solar installation in one integrated project, saving you time and money.' },
  ]},
  { category: 'Performance & Maintenance', items: [
    { q: 'Will solar panels work during a power outage?', a: 'Standard grid-tied solar systems shut off during outages for safety reasons. However, adding a battery storage system gives you backup power during outages. Our battery solutions can keep your essential systems running for hours or even days.' },
    { q: 'What happens on cloudy days?', a: 'Solar panels still produce energy on cloudy days, just at reduced output (typically 10-25% of normal). In the Central Valley, we enjoy over 260-270 sunny days per year. Your system is designed to account for seasonal and weather variations.' },
    { q: 'How long do solar panels last?', a: 'Modern solar panels are designed to last 25-30+ years. Most manufacturers warranty their panels for 25 years of performance, guaranteeing at least 80-85% of original output. Many panels continue producing well beyond their warranty period.' },
    { q: 'Do solar panels require maintenance?', a: 'Solar panels require very little maintenance. Rain naturally cleans them in most cases. We recommend an annual visual inspection and occasional cleaning if you notice heavy dust or debris buildup. There are no moving parts to wear out.' },
  ]},
  { category: 'Ownership vs. Leasing', items: [
    { q: 'Why do you recommend ownership over PPAs?', a: 'With ownership, you keep 100% of the financial benefits: the federal tax credit, increased home value, and all energy savings. PPAs and leases give those benefits to the solar company, not you. Ownership also means no escalating payments and complete control over your system.' },
    { q: 'How does owning compare to a PPA?', a: 'With a PPA, you\'re essentially renting panels and paying the company for electricity at a rate that often increases annually. With ownership, your costs are fixed (or zero after payback), you keep the 30% tax credit worth $7,500+, and your home value increases by $15,000-$25,000 on average.' },
    { q: 'Does solar increase my home value?', a: 'Yes. Studies show that solar panels increase home value by an average of $15,000-$25,000. Homes with owned solar systems (not leased) sell faster and for more money. In California, solar installations are also exempt from property tax increases under Proposition 13.' },
  ]},
];

const faqSchemaItems = faqs.flatMap((cat) =>
  cat.items.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a },
  }))
);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqSchemaItems,
};
---

<BaseLayout
  title="Solar FAQ | Common Solar Questions Answered | Solar Center by Dura-Foam"
  description="Get answers to common solar questions: costs, financing, installation timeline, equipment, maintenance, and more. Solar Center by Dura-Foam, Bakersfield CA."
  schema={schema}
>
  <PageHero title="Frequently Asked Questions" subtitle="Got questions about going solar? We've got answers." />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {faqs.map((category) => (
          <div>
            <h2 class="text-2xl font-bold text-solar-navy font-headline mb-6">{category.category}</h2>
            <div class="space-y-3">
              {category.items.map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-warm-sand">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-solar-navy font-headline mb-4">Still Have Questions?</h2>
      <p class="text-slate text-lg mb-8">Our solar experts are here to help. Get personalized answers during your free consultation.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center rounded-lg bg-solar-amber px-8 py-4 text-base font-bold text-midnight no-underline transition hover:bg-[#e6951a] font-label">Get Your Free Quote</a>
        <a href="tel:+16615962477" class="inline-flex items-center justify-center rounded-lg border-2 border-solar-navy px-8 py-4 text-base font-bold text-solar-navy no-underline transition hover:bg-solar-navy hover:text-white font-label">Call (661) 596-2477</a>
      </div>
    </div>
  </section>
</BaseLayout>
