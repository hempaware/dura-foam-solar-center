---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/sanger' },
  { label: 'Sanger', href: '/locations/sanger' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Sanger',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/sanger',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.7080,
    longitude: -119.5559,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Sanger' },
    { '@type': 'City', name: 'Fresno' },
    { '@type': 'City', name: 'Reedley' },
    { '@type': 'City', name: 'Squaw Valley' },
    { '@type': 'City', name: 'Orange Cove' },
    { '@type': 'City', name: 'Centerville' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is solar worth it for Sanger homeowners?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. Sanger receives approximately 275 sunny days per year, making it one of the best locations in California for solar energy. With PG&E rates continuing to rise and summer temperatures regularly exceeding 100°F, Sanger homeowners can save $150-$200+ per month on electricity bills. The 30% federal tax credit makes going solar even more affordable.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does solar installation take in Sanger?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The typical solar installation in Sanger takes 1-2 days for the physical installation. The full process from signed contract to system activation usually takes 6-10 weeks, which includes custom system design, Fresno County permitting, installation, inspection, and PG&E interconnection approval.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I go solar on an agricultural property in Sanger?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, we install solar on agricultural properties throughout the Sanger area. Agricultural solar installations can significantly reduce operating costs for farms and ranches. We design ground-mount and roof-mount systems for barns, packing houses, and residential properties on agricultural land. USDA REAP grants may also be available for qualifying agricultural operations.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Sanger CA | Local Solar Company | Solar Center"
  description="Sanger CA solar installation — Gateway to Kings Canyon. 275+ sunny days, save big on PG&E bills. Free consultation, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Sanger, CA"
    subtitle="Gateway to Kings Canyon — powered by sunshine. 275+ sunny days. Slash your PG&E bills with solar."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Sanger's Trusted Solar Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Known as the Gateway to Kings Canyon National Park, Sanger is a thriving agricultural community where hard-working families deserve energy independence. Solar Center by Dura-Foam provides custom-designed solar systems for Sanger homeowners and agricultural properties, helping you keep more of what you earn by cutting electricity costs.</p>
              <p>Sanger's Central Valley location delivers approximately 275 sunny days per year — ideal conditions for solar energy production. With summer temperatures frequently exceeding 100°F, air conditioning costs can dominate your PG&E bill. Solar panels transform that intense sunshine from a liability into an asset, dramatically reducing your monthly energy expenses.</p>
              <p>Whether you own a home in town, a ranch along the Kings River, or a working farm in the surrounding countryside, our team understands the unique solar needs of the Sanger community. We handle Fresno County permits, PG&E interconnection, and system design tailored to your property and energy usage.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Sanger Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">275+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$160+</p>
                <p class="text-sm text-slate">Average monthly summer bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Sanger Neighborhoods & Areas We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Downtown Sanger', 'North Sanger', 'South Sanger', 'Kings River Area', 'Centerville', 'Del Rey', 'Fresno', 'Reedley', 'Squaw Valley', 'Orange Cove', 'Piedra', 'Trimmer', 'Minkler', 'Wonder Valley', 'Tivy Valley'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Sanger Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'Is solar worth it for Sanger homeowners?', a: 'Absolutely. Sanger receives 275+ sunny days per year, making it ideal for solar. With rising PG&E rates and summer temps exceeding 100°F, homeowners can save $150-$200+ per month. The 30% federal tax credit makes it even more affordable.' },
                { q: 'How long does solar installation take in Sanger?', a: 'Physical installation takes 1-2 days. The full process from contract to activation is typically 6-10 weeks, including system design, Fresno County permitting, installation, inspection, and PG&E interconnection.' },
                { q: 'Can I go solar on an agricultural property in Sanger?', a: 'Yes, we install solar on agricultural properties throughout the Sanger area. We design ground-mount and roof-mount systems for farms, ranches, barns, and packing houses. USDA REAP grants may also be available for qualifying operations.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Sanger Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners throughout the Central Valley." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Wasco', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Clovis', cities: 'Clovis, Fresno, Tollhouse', href: '/locations/clovis' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
