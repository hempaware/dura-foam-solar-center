---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-gradient-to-br from-solar-navy via-midnight to-solar-navy py-16 lg:py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white font-headline leading-tight">{title}</h1>
    {subtitle && <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">{subtitle}</p>}
  </div>
</section>
