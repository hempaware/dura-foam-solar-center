---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Pomona', href: '/locations/pomona' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Pomona',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/pomona',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.0551,
    longitude: -117.7500,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Pomona' },
    { '@type': 'City', name: 'Claremont' },
    { '@type': 'City', name: 'La Verne' },
    { '@type': 'City', name: 'San Dimas' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Pomona?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Pomona costs between $15,000-$30,000 before the 30% federal tax credit. Pomona\'s inland location and hot summers mean larger systems may be needed, but higher production offsets the cost. We offer $0-down financing options to make solar affordable for every homeowner.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Pomona\'s inland climate good for solar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Excellent. Pomona gets more sun than coastal LA cities, with 287 sunny days per year. The warmer inland climate means higher AC usage, making solar savings even more significant. Modern panels are designed to perform well in hot conditions, and your system will produce more energy during peak demand hours.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are there solar incentives for Pomona residents?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Federal 30% tax credit, SCE net metering, and California\'s SGIP program for battery storage. SCE customers in Pomona benefit from time-of-use rate optimization with solar. These incentives can significantly reduce the overall cost of your solar installation.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Pomona CA | Expert Solar Installers | Solar Center"
  description="Pomona solar installation. Save on SCE bills in the Inland Valley. Free consultation, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Pomona, CA"
    subtitle="Inland Valley solar experts. 287 sunny days. Save big on SCE electricity bills."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Pomona Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Pomona sits in the heart of the Inland Valley, where hotter summers and more sunshine than coastal LA make solar energy an exceptional investment. With 287 sunny days per year and SCE electricity rates continuing to climb, Pomona homeowners are turning to solar at an accelerating pace. Solar Center by Dura-Foam brings decades of California solar expertise to Pomona and surrounding communities — from the revitalized Arts Colony district to the family neighborhoods of Phillips Ranch.</p>
              <p>Home to Cal Poly Pomona and near the prestigious Claremont Colleges, the area fosters a tech-forward, sustainability-minded community that embraces clean energy. Pomona's diverse housing stock — from mid-century ranch homes to newer construction — offers excellent rooftop solar potential. SCE's high time-of-use rates mean solar panels with smart inverters can maximize savings during peak afternoon hours when your system produces the most energy.</p>
              <p>The Inland Valley's warmer climate means higher air conditioning costs compared to coastal cities, but it also means more solar production. Our installation team designs systems optimized for Pomona's climate, ensuring maximum energy generation when you need it most. Whether you're in Downtown Pomona, the growing University Village area, or the established neighborhoods along Arrow Highway, we'll create a solar solution tailored to your home and energy needs.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Pomona Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">287</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$175+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Pomona Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Downtown Pomona', 'Phillips Ranch', 'South Pomona', 'Westmont', 'Indian Hill', 'Ganesha Hills', 'Claremont', 'La Verne', 'San Dimas', 'Lincoln Park', 'Arbol Verde', 'Pomona Arts Colony', 'University Village', 'Park West', 'Arrow Highway Corridor'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Pomona Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Pomona?', a: 'A typical residential solar installation in Pomona costs between $15,000-$30,000 before the 30% federal tax credit. Pomona\'s inland location and hot summers mean larger systems may be needed, but higher production offsets the cost. We offer $0-down financing options for every budget.' },
                { q: 'Is Pomona\'s inland climate good for solar?', a: 'Excellent. Pomona gets more sun than coastal LA cities, with 287 sunny days per year. The warmer inland climate means higher AC usage, making solar savings even more significant.' },
                { q: 'Are there solar incentives for Pomona residents?', a: 'Yes. Federal 30% tax credit, SCE net metering, and California\'s SGIP program for battery storage. SCE customers in Pomona benefit from time-of-use rate optimization with solar.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Pomona Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'West Covina', cities: 'West Covina, Covina, Azusa', href: '/locations/west-covina' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
