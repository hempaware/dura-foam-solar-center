---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Pasadena', href: '/locations/pasadena' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Pasadena',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/pasadena',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, #5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.1478,
    longitude: -118.1445,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Pasadena' },
    { '@type': 'City', name: 'Altadena' },
    { '@type': 'City', name: 'South Pasadena' },
    { '@type': 'City', name: 'San Marino' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Pasadena?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Pasadena costs between $15,000-$30,000 before the 30% federal tax credit. After the credit, most homeowners pay $10,500-$21,000. PWP may offer additional local incentives for Pasadena residents, further reducing your out-of-pocket costs. We offer $0-down financing options.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Pasadena Water and Power support solar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, PWP offers net metering and solar incentive programs. As a municipal utility, they provide streamlined interconnection for residential solar systems. Pasadena Water and Power has been proactive in supporting clean energy adoption, making it easier for homeowners to go solar and benefit from credits on excess energy produced.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can solar panels be installed on historic Craftsman homes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Absolutely. We specialize in installations that respect Pasadena\'s architectural heritage. Panels can be positioned to minimize visibility from the street while maximizing production. Our team has extensive experience working with historic homes in neighborhoods like Bungalow Heaven, ensuring your solar system complements your home\'s character.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Pasadena CA | Expert Solar Installers | Solar Center"
  description="Pasadena solar installation. PWP solar programs, Craftsman home expertise. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Pasadena, CA"
    subtitle="Pasadena Water & Power solar programs. Craftsman home solar expertise. The Rose City's trusted installer."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Pasadena Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Pasadena — the Rose City — is one of Southern California's most prestigious communities, and its homeowners are embracing solar energy at an accelerating pace. With 286 sunny days per year and beautiful tree-lined neighborhoods from Bungalow Heaven to San Rafael, Pasadena offers ideal conditions for residential solar. Solar Center by Dura-Foam brings decades of California solar expertise to this historic city and its surrounding communities.</p>
              <p>Pasadena is served by Pasadena Water and Power (PWP), the city's own municipal utility. PWP offers net metering and solar incentive programs with streamlined interconnection for residential systems. As a municipal utility, PWP sets its own solar policies, which can provide advantages over investor-owned utilities. This means Pasadena residents often enjoy a smoother path to solar adoption with favorable economics.</p>
              <p>Home to Caltech, JPL, and a thriving tech community, Pasadena is a city that understands innovation. Our installation team specializes in working with the diverse architectural styles found across Pasadena — from historic Craftsman bungalows in Bungalow Heaven and Madison Heights to mid-century homes in Hastings Ranch and modern residences throughout the city. We design systems that maximize production while respecting each home's unique character.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Pasadena Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">286</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$175+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Pasadena Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Old Town', 'East Pasadena', 'South Pasadena', 'Altadena', 'San Marino', 'Bungalow Heaven', 'Madison Heights', 'Hastings Ranch', 'Linda Vista', 'Orange Heights', 'Chapman Woods', 'San Rafael', 'Lamanda Park', 'Caltech area', 'Arroyo Seco'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Pasadena Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Pasadena?', a: 'A typical residential solar installation in Pasadena costs between $15,000-$30,000 before the 30% federal tax credit. PWP may offer additional local incentives for Pasadena residents. We offer $0-down financing options for every budget.' },
                { q: 'Does Pasadena Water and Power support solar?', a: 'Yes, PWP offers net metering and solar incentive programs. As a municipal utility, they provide streamlined interconnection for residential solar systems. PWP has been proactive in supporting clean energy adoption for Pasadena homeowners.' },
                { q: 'Can solar panels be installed on historic Craftsman homes?', a: 'Absolutely. We specialize in installations that respect Pasadena\'s architectural heritage. Panels can be positioned to minimize visibility from the street while maximizing production. Our team has extensive experience with historic homes in Bungalow Heaven and beyond.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Pasadena Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, #5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 7:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Glendale', cities: 'Glendale, La Crescenta, Montrose', href: '/locations/glendale' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
