---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/clovis' },
  { label: 'Clovis', href: '/locations/clovis' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Clovis',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/clovis',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.8252,
    longitude: -119.7029,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Clovis' },
    { '@type': 'City', name: 'Fresno' },
    { '@type': 'City', name: 'Sanger' },
    { '@type': 'City', name: 'Tollhouse' },
    { '@type': 'City', name: 'Prather' },
    { '@type': 'City', name: 'Friant' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much can Clovis homeowners save with solar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Clovis homeowners typically save $150-$250 per month on their PG&E bills after going solar. With approximately 275 sunny days per year and high summer cooling costs, most Clovis solar systems pay for themselves in 5-7 years. The 30% federal tax credit further reduces your upfront investment.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Clovis require special permits for solar panels?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, solar installations in Clovis require building permits through the City of Clovis Planning and Development Services. Solar Center handles all permitting, HOA approvals, and PG&E interconnection paperwork as part of our full-service installation. Most Clovis permits are approved within 2-3 weeks.',
      },
    },
    {
      '@type': 'Question',
      name: 'What solar financing options are available in Clovis?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We offer multiple financing options for Clovis homeowners including $0-down solar loans, lease options, and cash purchase discounts. Most homeowners choose our low-interest loan option, which allows you to start saving on electricity from day one with monthly payments lower than your current PG&E bill.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Clovis CA | Local Solar Company | Solar Center"
  description="Clovis CA solar installation experts. 275+ sunny days, Gateway to the Sierras. Save big on PG&E bills with custom solar. Free consultation, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Clovis, CA"
    subtitle="Gateway to the Sierras — and to smarter energy. 275+ sunny days. Maximum savings on PG&E bills."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Clovis's Trusted Solar Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Clovis homeowners know quality — from the tree-lined streets of Old Town to the newer master-planned communities along the Sierra foothills. Solar Center by Dura-Foam brings that same standard of excellence to every solar installation in Clovis. We design custom systems that match your home's architecture and energy needs.</p>
              <p>With approximately 275 sunny days per year and some of the highest summer temperatures in the Valley, Clovis is perfectly positioned for solar energy. Rising PG&E rates make air conditioning costs a major concern for families here — solar panels turn that abundant sunshine into real savings on your electricity bill.</p>
              <p>As a division of Dura-Foam Roofing & Solar Center, we understand the unique needs of Clovis homeowners. From navigating HOA requirements in communities like Harlan Ranch and Loma Vista to understanding Fresno County permitting, we handle every detail so you can enjoy hassle-free solar.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Clovis Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">275+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$180+</p>
                <p class="text-sm text-slate">Average monthly summer bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">85%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Clovis Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Old Town Clovis', 'Harlan Ranch', 'Loma Vista', 'Heritage Grove', 'Clovis North', 'Clovis East', 'Temperance Flat', 'Tarpey Village', 'Fresno', 'Sanger', 'Tollhouse', 'Prather', 'Friant', 'Academy', 'Dry Creek'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Clovis Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much can Clovis homeowners save with solar?', a: 'Clovis homeowners typically save $150-$250 per month on their PG&E bills after going solar. With 275+ sunny days per year and high summer cooling costs, most systems pay for themselves in 5-7 years.' },
                { q: 'Does Clovis require special permits for solar panels?', a: 'Yes, solar installations in Clovis require building permits through the City of Clovis Planning and Development Services. Solar Center handles all permitting, HOA approvals, and PG&E interconnection paperwork as part of our full-service installation.' },
                { q: 'What solar financing options are available in Clovis?', a: 'We offer $0-down solar loans, lease options, and cash purchase discounts. Most Clovis homeowners choose our low-interest loan option, which allows you to start saving on electricity from day one with payments lower than your current PG&E bill.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Clovis Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners throughout the Central Valley." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Wasco', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Sanger', cities: 'Sanger, Reedley, Squaw Valley', href: '/locations/sanger' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
