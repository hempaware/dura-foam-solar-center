---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Downey', href: '/locations/downey' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Downey',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/downey',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, #5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 33.9401,
    longitude: -118.1332,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Downey' },
    { '@type': 'City', name: 'Norwalk' },
    { '@type': 'City', name: 'Bellflower' },
    { '@type': 'City', name: 'Paramount' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Downey?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Downey costs between $15,000-$30,000 before the 30% federal tax credit. Downey\'s classic ranch-style homes with large roofs are ideal for solar installation. We offer $0-down financing options to make solar affordable for every homeowner in the Gateway Cities region.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is Downey good for solar energy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Excellent. With 286 sunny days per year and SCE\'s rising rates, Downey homeowners see strong returns on solar investment. The Gateway Cities region\'s flat terrain and open skies maximize solar exposure, making Downey one of the best areas in Southern California for residential solar energy.',
      },
    },
    {
      '@type': 'Question',
      name: 'What financing options are available for Downey solar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We offer $0-down financing, loans, and leases for Downey homeowners. Combined with the 30% federal tax credit, most Downey homeowners start saving from day one. Our team will help you find the financing option that best fits your budget and energy goals.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Downey CA | Gateway Cities Solar Experts | Solar Center"
  description="Downey solar installation. Gateway Cities solar experts. Save on SCE bills. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Downey, CA"
    subtitle="Gateway Cities solar experts. 286 sunny days. Save big on your SCE electricity bills."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Downey Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Downey sits at the heart of the Gateway Cities region — a community with deep roots in innovation. As the birthplace of the Apollo space program, where NASA's Space Shuttle orbiters were built at the former Downey Studios, this city has always looked toward the future. Today, Downey homeowners are embracing that same pioneering spirit by switching to solar energy and taking control of their electricity costs.</p>
              <p>With 286 sunny days per year and Southern California Edison's steadily rising rates, Downey is one of the best cities in the Gateway Cities for solar investment. Solar Center by Dura-Foam brings decades of California solar expertise to every neighborhood — from the classic mid-century ranch homes of North Downey to the diverse residential streets of South Downey and surrounding communities.</p>
              <p>Downey's housing stock is ideal for solar. The city's signature ranch-style homes feature large, unobstructed rooftops that maximize panel placement and energy production. Combined with the flat terrain and open skies of the Gateway Cities corridor, Downey homeowners consistently see some of the strongest solar returns in the greater Los Angeles area.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Downey Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">286</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$175+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Downey Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Downtown Downey', 'North Downey', 'South Downey', 'Norwalk', 'Bellflower', 'Paramount', 'South Gate', 'Pico Rivera', 'Santa Fe Springs', 'Hollydale', 'Imperial', 'Gallatin', 'Old River', 'Rio San Gabriel', 'Williams Tract'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Downey Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Downey?', a: 'A typical residential solar installation in Downey costs between $15,000-$30,000 before the 30% federal tax credit. Downey\'s classic ranch-style homes with large roofs are ideal for solar installation. We offer $0-down financing options for every budget.' },
                { q: 'Is Downey good for solar energy?', a: 'Excellent. With 286 sunny days and SCE\'s rising rates, Downey homeowners see strong returns. The Gateway Cities region\'s flat terrain and open skies maximize solar exposure.' },
                { q: 'What financing options are available for Downey solar?', a: 'We offer $0-down financing, loans, and leases. Combined with the 30% federal tax credit, most Downey homeowners start saving from day one.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Downey Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, #5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 7:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Norwalk', cities: 'Norwalk, Cerritos, La Mirada', href: '/locations/norwalk' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
