---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Palmdale', href: '/locations/palmdale' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Palmdale',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/palmdale',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, #5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.5794,
    longitude: -118.1165,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '07:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Palmdale' },
    { '@type': 'City', name: 'Sun Village' },
    { '@type': 'City', name: 'Littlerock' },
    { '@type': 'City', name: 'Pearblossom' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Palmdale?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Palmdale costs between $14,000-$28,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$19,600. With Palmdale\'s extreme sun exposure and high cooling costs, most systems pay for themselves in 5-7 years. We offer $0-down financing options.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does desert heat affect solar panel performance in Palmdale?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'While extreme heat can slightly reduce panel efficiency, Palmdale\'s 300+ sunny days far outweigh any heat-related losses. Modern panels are designed for high-temperature environments. We use tier-one panels rated for desert conditions and optimize panel placement to maximize airflow, keeping your system performing at peak levels year-round.',
      },
    },
    {
      '@type': 'Question',
      name: 'What solar incentives are available in Palmdale?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Palmdale homeowners can take advantage of the 30% federal Investment Tax Credit (ITC), California\'s net metering program through SCE, and various state rebate programs. SCE customers in the Antelope Valley benefit from net metering credits that offset high summer electricity costs. We help you maximize every available incentive.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Palmdale CA | Local Solar Company | Solar Center"
  description="Palmdale solar installation. 300+ sunny days in the Antelope Valley. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Palmdale, CA"
    subtitle="Harness the Antelope Valley's 300+ sunny days. Cut your SCE bill by up to 85%."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Palmdale's Trusted Solar Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Palmdale sits at the heart of the Antelope Valley — a high-desert community where sunshine is abundant and energy bills can be punishing. With summer temperatures regularly exceeding 100°F, air conditioning runs non-stop and SCE bills can soar past $300 or more. Solar Center by Dura-Foam helps Palmdale homeowners take back control of their energy costs with custom-designed solar systems built for the desert.</p>
              <p>The Antelope Valley receives over 300 sunny days per year, making Palmdale one of the best locations for solar energy in all of Southern California. Our systems are engineered specifically for desert conditions — we select high-temperature-rated panels and optimize mounting for maximum airflow, ensuring peak performance even during the hottest months.</p>
              <p>As a growing aerospace hub and thriving community, Palmdale is embracing solar at a rapid pace. From established neighborhoods around Rancho Vista to newer developments in Anaverde, homeowners across the city are making the switch. We handle everything from SCE interconnection to Palmdale city permitting, making the process seamless from first call to final inspection.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Palmdale Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">300+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$200+</p>
                <p class="text-sm text-slate">Average monthly summer bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">85%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Palmdale Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['East Palmdale', 'West Palmdale', 'Sun Village', 'Littlerock', 'Pearblossom', 'Rancho Vista', 'Joshua Hills', 'Desert View Highlands', 'Barrel Springs', 'Antelope Valley', 'Lake Palmdale', 'Anaverde', 'City Ranch', 'Shadow Hills', 'Tierra Subida'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Palmdale Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Palmdale?', a: 'A typical residential solar installation in Palmdale costs between $14,000-$28,000 before the 30% federal tax credit. After the credit, most homeowners pay $9,800-$19,600. With extreme sun exposure and high cooling costs, most systems pay for themselves in 5-7 years. We offer $0-down financing.' },
                { q: 'Does desert heat affect solar panel performance?', a: 'While extreme heat can slightly reduce panel efficiency, Palmdale\'s 300+ sunny days far outweigh any heat-related losses. We use tier-one panels rated for desert conditions and optimize placement for maximum airflow, keeping your system performing at peak levels year-round.' },
                { q: 'What solar incentives are available in Palmdale?', a: 'Palmdale homeowners can take advantage of the 30% federal Investment Tax Credit, California\'s net metering program through SCE, and various state rebate programs. SCE customers in the Antelope Valley benefit from net metering credits that offset high summer electricity costs.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Palmdale Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, #5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 7:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners throughout California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Delano, Tehachapi', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Lancaster', cities: 'Lancaster, Quartz Hill, Rosamond', href: '/locations/lancaster' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
