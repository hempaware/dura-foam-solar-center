---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Thank You', href: '/thank-you' },
];
---

<BaseLayout
  title="Thank You | Solar Center by Dura-Foam"
  description="Thank you for reaching out to Solar Center by Dura-Foam. A solar consultant will contact you within 24 hours."
  noindex={true}
>
  <PageHero title="Thank You! We've Received Your Request" subtitle="Your journey toward clean, affordable solar energy is officially underway." />
  <Breadcrumb items={breadcrumbs} />

  <!-- Confirmation & Next Steps -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-energy-green/10 mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-energy-green" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <p class="text-lg text-slate leading-relaxed">
          We appreciate you taking the time to reach out. Our team is reviewing your information now, and a dedicated solar consultant will be in touch shortly.
        </p>
      </div>

      <SectionHeading title="What Happens Next" subtitle="Here's what to expect over the coming hours." align="center" badge="Next Steps" />

      <div class="mx-auto max-w-4xl mt-12 grid gap-8 md:grid-cols-3">
        <!-- Step 1 -->
        <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-solar-amber text-midnight font-bold font-label text-lg mb-4">1</div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2">We Review Your Info</h3>
          <p class="text-slate text-sm leading-relaxed">Our team reviews your details to understand your home, energy usage, and solar goals so we can prepare a personalized recommendation.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-solar-amber text-midnight font-bold font-label text-lg mb-4">2</div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2">A Consultant Calls You</h3>
          <p class="text-slate text-sm leading-relaxed">Within 24 hours, a knowledgeable solar consultant will reach out to answer your questions and discuss your options — no pressure, just honest guidance.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-solar-amber text-midnight font-bold font-label text-lg mb-4">3</div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2">Schedule Your Free Consultation</h3>
          <p class="text-slate text-sm leading-relaxed">Together, we'll schedule a time for a detailed consultation, including a roof assessment and custom savings estimate tailored to your home.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Immediate Contact -->
  <section class="py-16 lg:py-20 bg-warm-sand">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-solar-navy font-headline mb-4">Need to Talk Sooner?</h2>
      <p class="text-slate text-lg mb-8 max-w-2xl mx-auto">
        If you'd rather not wait, give us a call right now. Our team is ready to help you get started on your solar journey today.
      </p>
      <a href="tel:+16615962477" class="inline-flex items-center justify-center rounded-lg bg-solar-amber px-8 py-4 text-base font-bold text-midnight no-underline transition hover:bg-[#e6951a] font-label">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call (661) 596-2477
      </a>
    </div>
  </section>

  <!-- Explore More -->
  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="While You Wait" subtitle="Learn more about solar energy and our process." align="center" />

      <div class="mx-auto max-w-4xl mt-12 grid gap-6 md:grid-cols-3">
        <a href="/how-solar-works" class="group rounded-xl border border-gray-200 bg-white p-8 text-center no-underline transition hover:border-solar-amber hover:shadow-lg">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-clean-sky/10 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-solar-navy" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          </div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2 group-hover:text-solar-amber transition-colors">How Solar Works</h3>
          <p class="text-slate text-sm leading-relaxed">Understand the technology behind your future solar system.</p>
        </a>

        <a href="/process" class="group rounded-xl border border-gray-200 bg-white p-8 text-center no-underline transition hover:border-solar-amber hover:shadow-lg">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-clean-sky/10 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-solar-navy" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2 group-hover:text-solar-amber transition-colors">Our Process</h3>
          <p class="text-slate text-sm leading-relaxed">See every step from consultation to powering on your panels.</p>
        </a>

        <a href="/faq" class="group rounded-xl border border-gray-200 bg-white p-8 text-center no-underline transition hover:border-solar-amber hover:shadow-lg">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-clean-sky/10 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-solar-navy" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <h3 class="text-lg font-bold text-solar-navy font-headline mb-2 group-hover:text-solar-amber transition-colors">FAQ</h3>
          <p class="text-slate text-sm leading-relaxed">Find answers to the most common solar questions.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
