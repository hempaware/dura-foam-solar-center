<script>
  // FAQ accordion
  const faqSection = document.getElementById('faq');
  if (faqSection) {
    const detailsElements = faqSection.querySelectorAll('details');
    detailsElements.forEach((detail) => {
      detail.addEventListener('toggle', () => {
        if (detail.open) {
          detailsElements.forEach((other) => {
            if (other !== detail) other.removeAttribute('open');
          });
        }
      });
    });
  }

  // Solar Designer Grid
  const panels = document.querySelectorAll('.solar-panel');
  const panelCountEl = document.getElementById('panel-count');
  const systemSizeEl = document.getElementById('system-size');
  const dailyOutputEl = document.getElementById('daily-output');
  const monthlyOutputEl = document.getElementById('monthly-output');

  function updateSolarMetrics() {
    const active = document.querySelectorAll('.solar-panel.active').length;
    const kw = (active * 0.44).toFixed(1);
    const daily = (active * 0.44 * 5.5).toFixed(1);
    const monthly = Math.round(active * 0.44 * 5.5 * 30);
    if (panelCountEl) panelCountEl.textContent = active;
    if (systemSizeEl) systemSizeEl.textContent = kw;
    if (dailyOutputEl) dailyOutputEl.textContent = daily;
    if (monthlyOutputEl) monthlyOutputEl.textContent = monthly;
  }

  panels.forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      btn.classList.toggle('bg-solar-amber');
      btn.classList.toggle('border-solar-amber');
      btn.classList.toggle('bg-white/5');
      btn.classList.toggle('border-white/20');
      btn.setAttribute('aria-pressed', btn.classList.contains('active'));
      updateSolarMetrics();
    });
  });

  // Savings Calculator
  const billSlider = document.getElementById('bill-slider');
  const billValueEl = document.getElementById('bill-value');
  const monthlySavingsEl = document.getElementById('monthly-savings');
  const totalSavingsEl = document.getElementById('total-savings');
  const systemCostEl = document.getElementById('system-cost');

  function calculateSavings() {
    const bill = parseInt(billSlider?.value || '200');
    const battery = parseInt(document.querySelector('input[name="battery"]:checked')?.value || '0');
    const term = parseInt(document.querySelector('input[name="term"]:checked')?.value || '20');
    const roof = document.querySelector('input[name="roof"]:checked')?.value || 'excellent';

    const roofFactor = roof === 'excellent' ? 1.0 : roof === 'good' ? 0.92 : 0.82;
    const systemKw = (bill / 30) * roofFactor;
    const costPerWatt = 2.70;
    const grossCost = systemKw * 1000 * costPerWatt;
    const batteryCost = battery * 12000;
    const totalGross = grossCost + batteryCost;
    const afterCredit = totalGross * 0.70;
    const monthlyPayment = afterCredit / (term * 12);
    const monthlySave = Math.max(0, bill - monthlyPayment);
    const rateEscalation = 1.04;
    let totalSave = 0;
    for (let yr = 0; yr < 25; yr++) {
      totalSave += monthlySave * 12 * Math.pow(rateEscalation, yr);
    }

    if (billValueEl) billValueEl.textContent = '$' + bill;
    if (monthlySavingsEl) monthlySavingsEl.textContent = '$' + Math.round(monthlySave);
    if (totalSavingsEl) totalSavingsEl.textContent = '$' + Math.round(totalSave).toLocaleString();
    if (systemCostEl) systemCostEl.textContent = '$' + Math.round(afterCredit).toLocaleString();
  }

  billSlider?.addEventListener('input', calculateSavings);

  document.querySelectorAll('.calc-option input[type="radio"]').forEach((radio) => {
    radio.addEventListener('change', (e) => {
      const group = e.target.closest('.grid');
      group?.querySelectorAll('.calc-option').forEach((label) => {
        label.classList.remove('border-solar-amber', 'bg-solar-amber/10', 'text-solar-navy');
        label.classList.add('border-gray-200', 'text-slate');
      });
      const selected = e.target.closest('.calc-option');
      selected?.classList.add('border-solar-amber', 'bg-solar-amber/10', 'text-solar-navy');
      selected?.classList.remove('border-gray-200', 'text-slate');
      calculateSavings();
    });
  });

  calculateSavings();

  // Environmental Impact Counter Animation
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target.querySelector('.stat-number');
        const raw = entry.target.dataset.value || '0';
        const suffix = entry.target.dataset.suffix || '';
        const hasComma = raw.includes(',');
        const hasK = raw.includes('K');
        const target = parseFloat(raw.replace(/[,K]/g, ''));
        const isDecimal = raw.includes('.');
        const multiplier = hasK ? 1 : 1;
        const duration = 2000;
        const steps = 60;
        let step = 0;

        const timer = setInterval(() => {
          step++;
          const progress = step / steps;
          const eased = 1 - Math.pow(1 - progress, 3);
          let current = target * eased;

          let display;
          if (hasK) {
            display = Math.round(current) + 'K';
          } else if (isDecimal) {
            display = current.toFixed(1);
          } else if (hasComma) {
            display = Math.round(current).toLocaleString();
          } else {
            display = Math.round(current).toString();
          }

          if (el) el.textContent = display + suffix;

          if (step >= steps) {
            clearInterval(timer);
            if (el) el.textContent = raw + suffix;
          }
        }, duration / steps);

        statObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.environmental-stat').forEach((stat) => {
    statObserver.observe(stat);
  });
</script>
