---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Inglewood', href: '/locations/inglewood' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Inglewood',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/inglewood',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 33.9617,
    longitude: -118.3531,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Inglewood' },
    { '@type': 'City', name: 'Hawthorne' },
    { '@type': 'City', name: 'Lennox' },
    { '@type': 'City', name: 'Westchester' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Inglewood?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Inglewood costs between $15,000-$30,000 before the 30% federal tax credit. Rising property values in Inglewood\'s renaissance make solar an especially smart investment. We offer $0-down financing options to make solar affordable for every homeowner.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is solar a good investment in Inglewood?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. With SoFi Stadium and the Intuit Dome driving neighborhood revitalization, property values are climbing. Solar increases home value while reducing monthly energy costs. Combined with 285 sunny days per year and SCE\'s rising rates, Inglewood homeowners see excellent returns on solar investment.',
      },
    },
    {
      '@type': 'Question',
      name: 'What solar incentives are available for Inglewood homeowners?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Inglewood homeowners can take advantage of the federal 30% tax credit, SCE net metering, California SGIP for battery storage, and potential local incentives through community reinvestment programs. Our team will help you maximize every available incentive.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Inglewood CA | Clean Energy for a City on the Rise | Solar Center"
  description="Inglewood solar installation. Join the Inglewood renaissance with clean energy. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Inglewood, CA"
    subtitle="Inglewood's solar energy partner. Clean energy for a city on the rise. Maximum SCE bill savings."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Inglewood Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Inglewood is a city in the midst of a remarkable renaissance. With SoFi Stadium, the Intuit Dome, and major development projects transforming the landscape, Inglewood homeowners are investing in their properties — and solar energy is one of the smartest investments they can make. Solar Center by Dura-Foam brings decades of California solar expertise to this vibrant community.</p>
              <p>With 285 sunny days per year and Southern California Edison's rising electricity rates, Inglewood is an excellent city for residential solar. As property values climb with the neighborhood revitalization, adding solar panels increases your home's value while dramatically reducing your monthly energy costs. It's a win-win for homeowners across Inglewood's diverse residential neighborhoods.</p>
              <p>From the tree-lined streets of Morningside Park to the revitalized corridors of Downtown Inglewood, our installation team understands the unique character of each neighborhood. Whether your home is a classic California bungalow near Centinela Park or a modern build in the Arbor Village area, we design solar systems that maximize production while complementing your home's architecture.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Inglewood Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">285</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$170+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">75%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Inglewood Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['Downtown Inglewood', 'Morningside Park', 'Centinela Park', 'Arbor Village', 'Hawthorne', 'Lennox', 'Westchester', 'Ladera Heights', 'View Park', 'Darby-Dixon', 'La Cienega Heights', 'North Inglewood', 'Lockhaven', 'Manchester Square', 'Athens'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Inglewood Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Inglewood?', a: 'A typical residential solar installation in Inglewood costs between $15,000-$30,000 before the 30% federal tax credit. Rising property values in Inglewood\'s renaissance make solar an especially smart investment.' },
                { q: 'Is solar a good investment in Inglewood?', a: 'Yes. With SoFi Stadium and the Intuit Dome driving neighborhood revitalization, property values are climbing. Solar increases home value while reducing monthly energy costs.' },
                { q: 'What solar incentives are available for Inglewood homeowners?', a: 'Federal 30% tax credit, SCE net metering, California SGIP for battery storage, and potential local incentives through community reinvestment programs.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Inglewood Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Torrance', cities: 'Torrance, Gardena, Redondo Beach', href: '/locations/torrance' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
