---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import QuoteForm from '../../components/QuoteForm.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Service Areas', href: '/locations/bakersfield' },
  { label: 'Lancaster', href: '/locations/lancaster' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Solar Center by Dura-Foam — Lancaster',
  telephone: '+1-661-596-2477',
  url: 'https://solarcenterca.com/locations/lancaster',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6730 Charity Ave, Suite 5',
    addressLocality: 'Bakersfield',
    addressRegion: 'CA',
    postalCode: '93308',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.6868,
    longitude: -118.1542,
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  areaServed: [
    { '@type': 'City', name: 'Lancaster' },
    { '@type': 'City', name: 'Quartz Hill' },
    { '@type': 'City', name: 'Lake Los Angeles' },
    { '@type': 'City', name: 'Leona Valley' },
  ],
  priceRange: '$$',
  image: 'https://solarcenterca.com/logos/logo-primary.svg',
  parentOrganization: {
    '@type': 'Organization',
    name: 'Dura-Foam Roofing & Solar Center',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does solar cost in Lancaster?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A typical residential solar installation in Lancaster costs between $15,000-$30,000 before the 30% federal tax credit. Lancaster\'s extreme sun means systems produce more power than in most California cities, often paying for themselves in just 5-7 years. With $0-down financing options available, going solar is affordable for every Lancaster homeowner.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does desert heat affect solar panels in Lancaster?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Modern solar panels are designed for extreme heat. While efficiency drops slightly above 77°F, Lancaster\'s 300+ sunny days more than compensate for any heat-related losses. We use heat-tolerant panels optimized for desert conditions, and our installation techniques ensure proper airflow beneath panels to minimize heat buildup and maximize energy production.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Lancaster require solar on new homes?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lancaster was the first city in the United States to mandate solar on new residential construction, reflecting the city\'s commitment to clean energy. Existing homeowners can also benefit tremendously from solar, with some of the highest return on investment in all of California thanks to Lancaster\'s exceptional sun exposure and high electricity costs from running air conditioning.',
      },
    },
  ],
};
---

<BaseLayout
  title="Solar Installation Lancaster CA | Expert Solar Installers | Solar Center"
  description="Lancaster solar installation. 300+ sunny days, Antelope Valley's solar leader. Free quote, $0 down financing. Solar Center by Dura-Foam. Call (661) 596-2477."
  schema={[schema, faqSchema]}
>
  <PageHero
    title="Solar Installation in Lancaster, CA"
    subtitle="300+ sunny days per year. Antelope Valley's premier solar installer. Maximum desert solar savings."
  />
  <Breadcrumb items={breadcrumbs} />

  <section class="py-16 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-5">
        <div class="lg:col-span-3 space-y-8">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-solar-navy font-headline mb-4">Lancaster Solar Installation Experts</h2>
            <div class="space-y-4 text-slate leading-relaxed">
              <p>Lancaster sits in the heart of the Antelope Valley — one of the sunniest places in all of California with over 300 days of sunshine per year. That exceptional solar resource, combined with high electricity bills driven by extreme desert heat and heavy air conditioning use, makes Lancaster one of the best cities in the nation for residential solar. Solar Center by Dura-Foam brings decades of California solar expertise to homeowners across the Antelope Valley.</p>
              <p>Lancaster made history as the first city in the United States to require solar panels on new home construction, cementing its reputation as a solar-forward community. The city is served by Southern California Edison (SCE), and with desert temperatures regularly exceeding 100°F in summer, Lancaster homeowners face some of the highest electricity bills in the state. Solar is the clear solution — our customers typically see an 85% reduction in their monthly electric bills.</p>
              <p>As an aerospace hub with Edwards Air Force Base nearby, Lancaster is a community that understands cutting-edge technology. Our installation team is experienced with the Antelope Valley's unique conditions — from high winds and extreme heat to the flat, open rooftops that are ideal for maximum solar panel coverage. We use heat-tolerant panels and desert-optimized mounting systems to ensure your system performs at its best for decades.</p>
            </div>
          </div>

          <div class="rounded-xl bg-warm-sand p-8">
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Why Lancaster Homeowners Go Solar</h3>
            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">300+</p>
                <p class="text-sm text-slate">Sunny days per year</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">$210+</p>
                <p class="text-sm text-slate">Average monthly electric bill</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">30%</p>
                <p class="text-sm text-slate">Federal tax credit</p>
              </div>
              <div>
                <p class="text-3xl font-extrabold text-solar-amber font-headline">85%</p>
                <p class="text-sm text-slate">Typical bill reduction</p>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Lancaster Neighborhoods We Serve</h3>
            <div class="grid gap-2 sm:grid-cols-3">
              {['West Lancaster', 'Downtown Lancaster', 'Quartz Hill', 'Lake Los Angeles', 'Leona Valley', 'Del Sur', 'Antelope Acres', 'Desert View', 'West Rancho Vista', 'Tierra Bonita', 'Joshua Hills', 'Anaverde', 'Westside', 'Amargosa Creek', 'Piute Ponds'].map((area) => (
                <span class="text-sm text-ink">{area}</span>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-xl font-bold text-solar-navy font-headline mb-4">Lancaster Solar FAQ</h3>
            <div class="space-y-4">
              {[
                { q: 'How much does solar cost in Lancaster?', a: 'A typical residential solar installation in Lancaster costs between $15,000-$30,000 before the 30% federal tax credit. Lancaster\'s extreme sun means systems produce more power, often paying for themselves in 5-7 years. We offer $0-down financing options.' },
                { q: 'How does desert heat affect solar panels in Lancaster?', a: 'Modern panels are designed for extreme heat. While efficiency drops slightly above 77°F, Lancaster\'s 300+ sunny days more than compensate. We use heat-tolerant panels optimized for desert conditions with proper airflow to minimize heat buildup.' },
                { q: 'Does Lancaster require solar on new homes?', a: 'Lancaster was the first US city to mandate solar on new construction. Existing homeowners can also benefit from solar, with some of the highest ROI in California thanks to exceptional sun exposure and high AC-driven electricity costs.' },
              ].map((faq) => (
                <details class="group rounded-xl border border-gray-200 bg-white">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-base font-semibold text-solar-navy font-headline">
                    {faq.q}
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-open:rotate-180 text-slate flex-shrink-0 ml-4" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="px-6 pb-4 text-slate text-sm leading-relaxed">{faq.a}</div>
                </details>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8">
          <div class="sticky top-24 space-y-6">
            <QuoteForm heading="Get Your Lancaster Solar Quote" />
            <div class="rounded-xl bg-white border border-gray-200 p-6">
              <h3 class="text-lg font-bold text-solar-navy font-headline mb-3">Visit Our Office</h3>
              <address class="not-italic text-sm text-slate space-y-2">
                <p class="font-semibold text-ink">Solar Center by Dura-Foam</p>
                <p>6730 Charity Ave, Suite 5</p>
                <p>Bakersfield, CA 93308</p>
                <a href="tel:+16615962477" class="block text-solar-navy font-semibold no-underline hover:text-solar-amber transition-colors">(661) 596-2477</a>
                <p>Mon-Fri: 9:00 AM - 5:00 PM</p>
              </address>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading title="Other Service Areas" subtitle="We serve homeowners across California." />
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { name: 'Bakersfield', cities: 'Bakersfield, Oildale, Shafter, Delano', href: '/locations/bakersfield' },
          { name: 'Fresno', cities: 'Fresno, Clovis, Visalia, Tulare', href: '/locations/fresno' },
          { name: 'Sacramento', cities: 'Sacramento, Elk Grove, Roseville', href: '/locations/sacramento' },
          { name: 'Palmdale', cities: 'Palmdale, Sun Village, Littlerock', href: '/locations/palmdale' },
        ].map((area) => (
          <a href={area.href} class="rounded-xl bg-white p-6 border border-gray-200 hover:border-solar-amber hover:shadow-md transition-all no-underline group">
            <h3 class="font-bold text-solar-navy group-hover:text-solar-amber transition-colors">{area.name}</h3>
            <p class="text-sm text-slate mt-1">{area.cities}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
